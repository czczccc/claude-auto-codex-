PORT=3000
LOG_LEVEL=info
DRY_RUN=true

GITHUB_APP_WEBHOOK_SECRET=replace-me
GITHUB_TOKEN=ghp_replace_me
GITHUB_AUTO_LABEL=auto-dev
GITHUB_DEFAULT_BASE_BRANCH=main
REPO_ROOT=./repos
REPO_CONFIG_PATH=./repositories.json
REPO_ALLOWLIST=your-org/your-repo,another-org/another-repo

WORKTREE_ROOT=./data/worktrees
DB_PATH=./data/orchestrator.sqlite

PLANNER_API_BASE_URL=https://api.deepseek.com/v1
PLANNER_API_KEY=replace-me
PLANNER_MODEL=deepseek-chat

CODEX_COMMAND=codex
CODEX_ARGS=exec --full-auto
MAX_REVIEW_LOOPS=2
